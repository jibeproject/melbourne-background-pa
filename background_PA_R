hse <- raw_hse %>%
  filter(Age16g5 > 0) %>% 
  mutate(mmetHr_swimming = ifelse(DayExc01 >= 1 & DayExc01 <= 28 & ExcTim01 > 0, (DayExc01 * ExcTim01) / 240, 0)*ifelse(ag16g10<6,4.8,4.8),
         mmetHr_workingout = ifelse(DayExc03 >= 1 & DayExc03 <= 28 & ExcTim03 > 0, (DayExc03 * ExcTim03) / 240, 0)*ifelse(ag16g10<6,4,4),
         mmetHr_aerobics = ifelse(DayExc04 >= 1 & DayExc04 <= 28 & ExcTim04 > 0, (DayExc04 * ExcTim04) / 240, 0)*ifelse(ag16g10<6,6.3,6.3),
         mmetHr_dance = ifelse(DayExc05 >= 1 & DayExc05 <= 28 & ExcTim05 > 0, (DayExc05 * ExcTim05) / 240, 0)*ifelse(ag16g10<6,4,4),
         mmetHr_running = ifelse(DayExc06 >= 1 & DayExc06 <= 28 & ExcTim06 > 0, (DayExc06 * ExcTim06) / 240, 0)*ifelse(ag16g10<6,6.5,6.5),
         mmetHr_football = ifelse(DayExc07 >= 1 & DayExc07 <= 28 & ExcTim07 > 0, (DayExc07 * ExcTim07) / 240, 0)*ifelse(ag16g10<6,5.3,5.3),
         mmetHr_badminton = ifelse(DayExc08 >= 1 & DayExc08 <= 28 & ExcTim08 > 0, (DayExc08 * ExcTim08) / 240, 0)*ifelse(ag16g10<6,5.8,5.8),
         mmetHr_squash = ifelse(DayExc09 >= 1 & DayExc09 <= 28 & ExcTim09 > 0, (DayExc09 * ExcTim09) / 240, 0)*ifelse(ag16g10<6,6.3,6.3),
         mmetHr_exercises = ifelse(DayExc10 >= 1 & DayExc10 <= 28 & ExcTim10 > 0, (DayExc10 * ExcTim10) / 240, 0)*ifelse(ag16g10<6,3.5,3.5),
         mmetHr_sports = pmin(mmetHr_swimming+mmetHr_workingout+mmetHr_aerobics+mmetHr_dance+mmetHr_running+mmetHr_football+mmetHr_badminton+mmetHr_squash+mmetHr_exercises,240),
         time_cycling = pmin(ifelse(DayExc02 >= 1 & DayExc02 <= 28 & ExcTim02 > 0, (DayExc02 * ExcTim02) / 240, 0),40),
         age_lt65 = ag16g10 < 6) %>%
  group_by(Sex, age_lt65) %>%
  mutate(
    p60_sports_active = quantile(mmetHr_sports,0.60, na.rm = TRUE),
    mmetHr_sports = case_when(
      !age_lt65                              ~ mmetHr_sports,
      mmetHr_sports > 0 & mmetHr_sports < p60_sports_active ~ mmetHr_sports*10,
      mmetHr_sports > p60_sports_active ~ mmetHr_sports,
      TRUE  ~ mmetHr_sports)) %>%
  ungroup() %>%
  select(id = SerialA,
         gender = Sex,
         age_group = ag16g10,
         time_sports = hrs10spt,
         time_totalpa = hrs10tot08,
         mmetHr_sports,
         imd_original = qimd,
         time_manual = hrs10man,
         time_walk = hrs10wlka,
         time_home = hrs10hwk,
         time_cycling) %>% 
  filter(age_group > 0 & time_totalpa >= 0) %>% 
  mutate(#
    time_manual = pmin(time_manual, 40),
    time_walk = pmin(time_walk, 40),
    time_home = pmin(time_home, 40),
    time_sport_without_cycling = time_sports - time_cycling,
    mmetHr_totalpa = time_totalpa * 4,
    mmetHr_walk = time_walk*2.5,
    mmetHr_cycling = time_cycling*5.8,
    mmetHr_manual = time_manual*4.5,
    gender = if_else(gender == 2, "Female", "Male"),
    age_group = case_when(
      age_group == 1 ~ "16-24",
      age_group == 2 ~ "25-34",
      age_group == 3 ~ "35-44",
      age_group == 4 ~ "45-54",
      age_group == 5 ~ "55-64",
      age_group == 6 ~ "65-74",
      age_group == 7 ~ "75+",
      TRUE ~ NA_character_),
    imd = case_when(imd_original == 1 ~ "5 - Least Deprived", # least deprived
                    imd_original == 2 ~ "4",
                    imd_original == 3 ~ "3",
                    imd_original == 4 ~ "2",
                    imd_original == 5 ~ "1 - Most Deprived"), # most deprived
    mmetHr_home = case_when(imd %in% c("5 - Least Deprived", "4") ~ time_home*2*5,
                            imd %in% c("3") ~ time_home*2*3,
                            imd %in% c("2") ~ time_home*2*2,
                            TRUE ~ time_home*2*1),
    mmetHr_sport_manual_home = pmin(mmetHr_sports+mmetHr_manual+mmetHr_home, 240))


